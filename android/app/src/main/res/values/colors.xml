<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Brand color matches indigo-600 used throughout the app. -->
    <color name="colorPrimary">#4F46E5</color>
    <color name="colorPrimaryDark">#4338CA</color>
    <color name="colorAccent">#6366F1</color>

    <!-- Surface colors written by the StatusBar / NavigationBar plugins at
         runtime when the theme toggles. Defined here as a fallback so the
         very first frame after launch matches the app shell instead of
         rendering as a blank black strip. -->
    <color name="systemSurfaceLight">#FFFFFF</color>
    <color name="systemSurfaceDark">#0F172A</color>
</resources>
