{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite\"",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:apk": "pnpm build && pnpm exec cap sync android && cmd /c \"set JAVA_HOME=C:\\Program Files\\Android\\Android Studio\\jbr&& set ANDROID_HOME=%LOCALAPPDATA%\\Android\\Sdk&& cd android && .\\gradlew assembleDebug\"",
    "zip": "git archive -o project.zip HEAD"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/status-bar": "^8.0.2",
    "@capawesome-team/capacitor-file-opener": "^8.0.1",
    "@hugotomazi/capacitor-navigation-bar": "^4.0.1",
    "@supabase/supabase-js": "^2.108.2",
    "clsx": "2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "firebase": "^12.15.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "tailwind-merge": "3.4.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "22.19.17",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.1.2",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.1.17",
    "typescript": "5.9.3",
    "vite": "^8.0.16",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.9"
  }
