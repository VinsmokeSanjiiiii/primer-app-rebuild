{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Path mapping — baseUrl is retained for alias support.
       TypeScript 5.9+ emits a deprecation notice when baseUrl is set alongside
       certain module modes; keepBaseUrl is still needed for path aliases to
       resolve correctly with the "bundler" moduleResolution strategy.
       If the warning becomes a build-break in a future version, migrate
       to tsconfig "paths" with fully-qualified prefixes instead. */
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src", "vite.config.ts"]
}
