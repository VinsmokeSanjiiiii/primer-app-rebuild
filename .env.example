# =============================================================
# PrimerHR — Environment Variables
# =============================================================
# Copy this file to `.env` and fill in your Supabase credentials.
# These are loaded by Vite at build time and prefixed with VITE_
# so they are available in client-side code.
#
# IMPORTANT: Never commit your .env file to version control.
# =============================================================

# Supabase project URL (e.g. https://xyzcompany.supabase.co)
VITE_SUPABASE_URL=

# Supabase anonymous/public key (safe for client-side use with RLS)
VITE_SUPABASE_ANON_KEY=
