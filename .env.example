# =============================================================
# Primer Communications — Firebase Configuration
# =============================================================
# The web client talks to the Firebase Realtime Database (primerdb2).
# The project config is embedded in `src/data/firebase.ts` so the app
# works out of the box; you do NOT need to copy these values into a `.env` file.
#
# If you want to point the app at a different Firebase project
# (for example a development sandbox), override the values below:
#
#   VITE_FB_API_KEY=...
#   VITE_FB_AUTH_DOMAIN=...
#   VITE_FB_DATABASE_URL=...
#   VITE_FB_PROJECT_ID=...
#   VITE_FB_STORAGE_BUCKET=...
#   VITE_FB_MESSAGING_SENDER_ID=...
#   VITE_FB_APP_ID=...
#
# These are read in `src/data/firebase.ts`. When set, they
# override the embedded `primerdb2` project config.
#
# For development offline mode (using seed data instead of Firebase):
#   VITE_OFFLINE_MODE=true
# =============================================================

VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_DATABASE_URL=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_SENDER_ID=
VITE_FB_APP_ID=
VITE_OFFLINE_MODE=
